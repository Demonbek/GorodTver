<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    package="ru.gorod_dubna.gorod_dubna">

    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.ACCESS_WIFI_STATE" />
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />
    <uses-permission android:name="android.permission.ACCESS_COARSE_LOCATION" />
    <uses-permission android:name="android.permission.ACCESS_FINE_LOCATION" />
    <uses-permission android:name="android.permission.ACCESS_GPS" />
    <uses-permission android:name="android.permission.ACCESS_ASSISTED_GPS" />
    <uses-permission android:name="android.permission.ACCESS_LOCATION" />

    <application
        android:allowBackup="true"
        android:fullBackupContent="true"
        android:icon="@mipmap/ic_goroddubna"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_goroddubna_round"
        android:supportsRtl="false"
        android:theme="@style/AppTheme.NoActionBar"
        android:usesCleartextTraffic="true"
        tools:ignore="GoogleAppIndexingWarning"
        tools:targetApi="m">
        <activity
            android:name=".HomeActivity"
            android:label="@string/app_name"
            android:theme="@style/AppTheme.NoActionBar" />
        <activity
            android:name=".Transport"
            android:label="Транспорт"
            android:parentActivityName=".HomeActivity"
            android:theme="@style/AppTheme" />
        <activity
            android:name=".CamWeb"
            android:label="@string/action_webcam1"
            android:parentActivityName=".HomeActivity"
            android:theme="@style/AppTheme" />

        <meta-data
            android:name="com.google.firebase.messaging.default_notification_icon"
            android:resource="@drawable/ic_stat" />

        <activity
            android:name=".Zastavka"
            android:theme="@style/Theme.AppCompat.Light.NoActionBar">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />

                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <activity
            android:name=".History"
            android:label="О городе"
            android:parentActivityName=".HomeActivity"
            android:theme="@style/AppTheme"
            tools:targetApi="jelly_bean">
            <meta-data
                android:name="android.support.PARENT_ACTIVITY"
                android:value="ru.gorod_dubna.gorod_dubna.HomeActivity" />
        </activity>
        <activity
            android:name=".News"
            android:label="Новости"
            android:parentActivityName=".HomeActivity"
            android:theme="@style/AppTheme"/>
        <activity
            android:name=".Ads"
            android:label="Объявления"
            android:parentActivityName=".HomeActivity"
            android:theme="@style/AppTheme"/>
        <activity
            android:name=".Pogoda"
            android:label="Погода"
            android:parentActivityName=".HomeActivity"
            android:theme="@style/AppTheme"/>
        <activity
            android:name=".Jobs"
            android:label="Вакансии"
            android:parentActivityName=".HomeActivity"
            android:theme="@style/AppTheme"/>
        <activity
            android:name=".Telefony"
            android:label="Телефоны"
            android:parentActivityName=".HomeActivity"
            android:theme="@style/AppTheme"
            tools:targetApi="jelly_bean">
            <meta-data
                android:name="android.support.PARENT_ACTIVITY"
                android:value="ru.gorod_dubna.gorod_dubna.HomeActivity" />
        </activity>
        <activity
            android:name=".Afisha"
            android:label="Афиша"
            android:parentActivityName=".HomeActivity"
            android:theme="@style/AppTheme" />
        <activity android:name=".Onas" />

        <service
            android:name=".MyFirebaseMessagingService"
            tools:ignore="ExportedService">
            <intent-filter>
                <action android:name="com.google.firebase.MESSAGING_EVENT" />
            </intent-filter>
        </service>

        <activity
            android:name="com.my.target.common.MyTargetActivity"
            android:configChanges="keyboard|keyboardHidden|orientation|screenLayout|uiMode|screenSize|smallestScreenSize" />
    </application>

</manifest>